# Application
APP_NAME=Super Agent Liquidity & Risk Intelligence API
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# API
API_V1_PREFIX=/api/v1

# Database
DATABASE_URL=sqlite:///./super_agent.db
SQL_ECHO=false

# CORS
# Use a comma-separated list of allowed frontend origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Synthetic data files
TRANSACTIONS_FILE=data/synthetic/transactions.csv
OPENING_BALANCES_FILE=data/synthetic/opening_balances.csv
GROUND_TRUTH_FILE=data/ground_truth/scenario_labels.csv

# Replay
DEFAULT_REPLAY_SPEED=10
REPLAY_BATCH_SIZE=20

# Liquidity forecasting
LIQUIDITY_LOOKBACK_MINUTES=30
LIQUIDITY_SAFETY_BUFFER_PERCENT=15
LIQUIDITY_WATCH_MINUTES=120
LIQUIDITY_CRITICAL_MINUTES=60

# Feed health
FEED_STALE_MINUTES=15
FEED_MISSING_MINUTES=30

# Anomaly detection
ANOMALY_MEDIUM_THRESHOLD=40
ANOMALY_HIGH_THRESHOLD=70
ANOMALY_WINDOW_MINUTES=15
ANOMALY_BASELINE_MINUTES=180
ANOMALY_MIN_TRANSACTIONS=6
ANOMALY_AMOUNT_TOLERANCE_PERCENT=2.0

# OpenAI explanations
# Never commit a real API key. Add it only to your local .env or hosting provider.
OPENAI_API_KEY=
OPENAI_EXPLANATIONS_ENABLED=true
OPENAI_EXPLANATION_MODEL=gpt-5.6-terra
OPENAI_EXPLANATION_TIMEOUT_SECONDS=20
OPENAI_EXPLANATION_MAX_OUTPUT_TOKENS=900
